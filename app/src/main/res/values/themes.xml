<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Matches MagicOSLightColorScheme.background in Theme.kt so there is no
             color flash before Compose takes over, and so system windows (e.g. the
             recents-app card) don't show a mismatched color. -->
        <item name="android:windowBackground">#FFF5F7FA</item>
        <item name="android:statusBarColor">#FFF5F7FA</item>
        <item name="android:navigationBarColor">#FFF5F7FA</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>
</resources>
